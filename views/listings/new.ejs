 <%- layout("/layouts/boillerplate") -%>
<div class="row mt-3">
  <div class="col-8 offset-2">
  <!-- <br> <br> -->
  <h3> create a new Listing</h3>
    
<form method="POST"  action="/listings"     class="needs-validation"  novalidate enctype="multipart/form-data"><!--1-->
                     <div class="mb-3">
                     <label for="title" class="form-label"> title</label> <br>         
                     <input
                      name="listings[title]"
                      placeholder= "Add acatchy title"
                      type="text" 
                      class="form-control"  required/><!--2-->
                      <div class="valid-feedback">Title is good!</div>
                       </div>


                        <div class="mb-3">
                        <label for="description" class="form-label">description</label>            <br>
                        <textarea 
                        name="listings[description]"
                        class="form-control"  required/></textarea>
                        
                         <div class="invalid-feedback">plase enter the short description!</div>
                         </div>


                       


                          <!-- file -->

                          <div class="mb-3">
                          <label for="image" class="form-label">Upload Listing image </label>            <br>
                          <input name="listings[image]" 
                          type="file"
                          class="form-control"
                          required>
                          </div>
                          

                          <div class="row">
                          <div class="mb-3 col-md-4">
                          <label for="price" class="form-label">price</label>            <br>
                          <input name="listings[price]"
                          placeholder="1200"
                          class="form-control"required/><!--5-->
                          <div class="invalid-feedback">
                          price should be valid!!</div>
                          </div>
                          <div class="mb-3  col-md-8">
                          <label for="country" class="form-label">country</label>            <br>
                          <input name="listings[country]" 
                          placeholder="IND" 
                          type="text" 
                          class="form-control"
                          required/>
                          <div class="invalid-feedback">
                          country name should be valid!</div>
                          </div>
                          </div>



                          <div class="mb-3">
                          <label for="location" class="form-label">location</label>
                          <br>
                          <input name="listings[location]" 
                          placeholder="japur, rajstan" 
                          type="text"   
                          class="form-control" required/><!--6-->
                          <div class="invalid-feedback"> 
                          location should be valid!</div>
                          </div>



                               <br  /> <br   />
                   <button class="btn btn-dark   add-btn mt-3">Add</button>
             <br> <br/>
        </form> 
    </div>
</div>